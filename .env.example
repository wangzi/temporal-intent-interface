# ───────────────────────────────────────────────────────────────────
# tii env template — copy to `.env.local` and fill in.
# Every variable below is validated at boot via `src/lib/env.ts`;
# missing/malformed → fail loud.
# ───────────────────────────────────────────────────────────────────

# Public canonical site URL. No trailing slash.
# Local dev: http://localhost:3000   Prod: https://z.stillinlove.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# journalkit engine API base URL. Server-side only — no NEXT_PUBLIC_.
# Prod: https://studio.stillinlove.co/api/v1
JOURNALKIT_API_URL=https://studio.stillinlove.co/api/v1

# journalkit engine API key. Server-side only — NEVER expose.
# Held by the BFF (src/lib/engine/client.ts); the browser never sees it.
JOURNALKIT_API_KEY=

# When true, the engine client reads from src/lib/engine/fixtures/*.json
# instead of calling the real API. Phase B default while Phase A is in flight.
JOURNALKIT_FIXTURE_MODE=true

# ───────────────────────────────────────────────────────────────────
# Lens controls (left rail) — CLIENT-side, so NEXT_PUBLIC_ (inlined into
# the browser bundle). NOT validated by src/lib/env.ts; read directly in
# src/lib/lens/*. They power Google sign-in + snapshot create/read, which
# talk to journalkit from the browser (Bearer the Supabase JWT). Snapshot
# create requires a real engine (not fixtures) so post_id maps to a
# journalkit entry id; the public /s/[token] read needs no session.
# ───────────────────────────────────────────────────────────────────

# journalkit API ORIGIN — origin only, NO /api/v1 suffix (the Lens client
# appends it). Distinct from the server-only JOURNALKIT_API_URL above.
NEXT_PUBLIC_API_URL=https://studio.stillinlove.co

# journalkit Supabase project (zrbvwywfgdptvgbsgykb) — Google sign-in.
# The anon/publishable key is safe in the client bundle; still left blank
# here so nothing is committed. Fill in .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://zrbvwywfgdptvgbsgykb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
